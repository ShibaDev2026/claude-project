# claude-project Smoke Test 環境變數
# 用途：提供 java-smoke-test.sh 啟動容器時所需的最小設定
# 說明：claude-project 含 spring-boot-starter-data-jpa 但無 @Entity / @Repository
#       排除 DataSource / JPA 自動配置，避免啟動時因缺少 DB driver 而失敗
SPRING_AUTOCONFIGURE_EXCLUDE=org.springframework.boot.jdbc.autoconfigure.DataSourceAutoConfiguration,org.springframework.boot.hibernate.autoconfigure.HibernateJpaAutoConfiguration
